{
  "name": "p5-sketches",
  "version": "1.0.0",
  "description": "Mathematical visualizations with p5.js",
  "scripts": {
    "serve": "python3 -m http.server 3000",
    "test:e2e": "playwright test",
    "docker:build": "docker compose -f docker-compose.e2e.yml build",
    "docker:test": "docker compose -f docker-compose.e2e.yml run --rm e2e",
    "docker:test:debug": "docker compose -f docker-compose.e2e.yml run --rm --service-ports e2e-debug"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
