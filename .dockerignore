# Dependencies - installed fresh in container
node_modules/

# Test artifacts - mounted as volumes
playwright-report/
test-results/

# Build outputs
dist/
build/
.next/
out/

# IDE and editor
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Git
.git/
.gitignore

# Docker files (not needed inside container)
Dockerfile*
docker-compose*.yml
.dockerignore

# Environment files (avoid leaking secrets)
.env
.env.*
!.env.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
Thumbs.db
